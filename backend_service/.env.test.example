# Variables de entorno para el sistema de pruebas E2E automatizadas.
# Copia este archivo como .env.test y ajusta los valores a tu entorno local.
# Este archivo NO se sube a Git (protegido por .gitignore).
# Las pruebas crearán la base de datos gym_test_db automáticamente si no existe.

NODE_ENV=test
DB_HOST=127.0.0.1
DB_PORT=5435               # El mismo puerto que tu Docker de Postgres (ver docker-compose)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=gym_test_db        # BD EXCLUSIVA para tests — NO la misma que gym_db

# Secrets dummy para tests: NO usar secrets reales aquí
JWT_SECRET=test_jwt_secret_for_e2e_only
JWT_EXPIRATION=1h
JWT_INVITE_SECRET=test_invite_secret_for_e2e_only
JWT_REFRESH_SECRET=test_refresh_secret_for_e2e_only
JWT_REFRESH_EXPIRATION=7d

PORT=3002                  # Puerto diferente al de desarrollo (3001)
GOOGLE_CLIENT_ID=dummy
GOOGLE_CLIENT_SECRET=dummy
